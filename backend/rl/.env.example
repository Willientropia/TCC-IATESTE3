# ==================== Credenciais Firebase ====================
FB_API_KEY=sua_api_key_aqui
FB_URL=https://seu-projeto-default-rtdb.firebaseio.com
FB_EMAIL=seu_email@gmail.com
FB_PASS=sua_senha_aqui

# ==================== Configuração do Dispositivo ====================
DEVICE_ID=esp32_01

# ==================== Caminhos Firebase (Customizáveis) ====================
# Caminho para leitura do tempo real. Ex: /devices/{DEVICE_ID}/realtime
PATH_REALTIME=/devices/esp32_01/realtime

# Caminho para leitura de históricos diários. Ex: /devices/{DEVICE_ID}/leituras
PATH_HISTORY=/devices/esp32_01/leituras

# Caminho para disparo de comandos. Ex: /devices/{DEVICE_ID}/commands
PATH_COMMANDS=/devices/esp32_01/commands

# Caminho para salvar log do dashboard. Ex: /devices/{DEVICE_ID}/ai_dashboard
PATH_DASHBOARD=/devices/esp32_01/ai_dashboard
